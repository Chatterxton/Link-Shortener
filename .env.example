# =====================================================================
# Link shortener environment.
# Architecture: external nginx on the host proxies to backend & frontend
# containers, which are bound only to 127.0.0.1 (not exposed publicly).
# =====================================================================

# ---- Public-facing settings ----
# Domain users see (no scheme, no trailing slash). Example: short.example.com
PUBLIC_DOMAIN=localhost
# Scheme: http or https
PUBLIC_SCHEME=http
# Optional explicit port suffix in displayed short URLs
# Leave empty in production (default 80/443 via nginx).
# Use ":8080" only for direct-to-backend access without nginx (dev).
PUBLIC_PORT_SUFFIX=

# ---- Host ports (published only on 127.0.0.1, used as nginx upstreams) ----
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ---- Postgres ----
POSTGRES_USER=shortener
POSTGRES_PASSWORD=change_me
POSTGRES_DB=shortener
POSTGRES_PORT=5432

# ---- Backend ----
JWT_SECRET=change_me_to_a_long_random_string
SHORT_CODE_LENGTH=7
JWT_TTL_HOURS=72

# ---- Frontend ----
# URL the browser uses to reach the API.
# In production behind nginx leave EMPTY -- the browser will hit the same
# origin (relative paths) and nginx will route /api/* to the backend.
# For local dev without nginx set e.g. http://localhost:8080
NEXT_PUBLIC_API_BASE=
